# =============================================================================
# Banha Real Estate — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit your .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Required)
# -----------------------------------------------------------------------------
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://banha_user:your_strong_password@localhost:5432/banha_realestate

# -----------------------------------------------------------------------------
# Server (Optional — defaults shown)
# -----------------------------------------------------------------------------
# Port the API server listens on
PORT=3001

# Node environment: development | production
NODE_ENV=production

# -----------------------------------------------------------------------------
# JWT / Auth (Required for authentication features)
# -----------------------------------------------------------------------------
JWT_SECRET=replace_with_a_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# File Upload (Optional — for property image uploads)
# -----------------------------------------------------------------------------
# Max upload size in MB
MAX_UPLOAD_MB=10
# Upload storage path (relative to server root)
UPLOAD_DIR=./uploads

# -----------------------------------------------------------------------------
# Email / SMTP (Optional — for notification templates)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="عقارات بنها <noreply@banha.estate>"

# -----------------------------------------------------------------------------
# App Config (Optional)
# -----------------------------------------------------------------------------
# Public URL of the deployed site (used in email links, sitemaps, etc.)
APP_URL=https://yourdomain.com

# Admin credentials (first-run bootstrap — change immediately after setup)
ADMIN_EMAIL=admin@banha.com
ADMIN_PASSWORD=change_me_immediately
